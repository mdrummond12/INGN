rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns a single doc keyed by their Firebase Auth uid, plus a
    // profiles subcollection. Only the owning user can ever read or write
    // their own data — there's no cross-user access of any kind.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /profiles/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
