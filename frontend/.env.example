# Copy to .env.local for local development. These values are public — they
# ship in the JS bundle. Security comes from Firebase Auth + the backend's
# token verification, not from hiding them.

# Firebase web config — Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=ingn-2e1e9.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ingn-2e1e9
VITE_FIREBASE_APP_ID=

# GraphQL endpoint
# Local dev:  http://localhost:8080/graphql
# Production: https://ingn-api--ingn-2e1e9.us-central1.hosted.app/graphql
VITE_GRAPHQL_URL=http://localhost:8080/graphql
